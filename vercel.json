{
  "version": 2,
  "routes": [
    { "src": "/health",        "dest": "/api/cron" },
    { "src": "/seo.js",        "dest": "/api/seo" },
    { "src": "/api/seo.js",    "dest": "/api/seo" },
    { "src": "/api/seo/(.+)",  "dest": "/api/seo/[siteId]?siteId=$1" },
    { "src": "/api/track",     "dest": "/api/track" },
    { "src": "/api/dashboard", "dest": "/api/dashboard" },
    { "src": "/api/client",    "dest": "/api/client" },
    { "src": "/api/auth",      "dest": "/api/auth" },
    { "src": "/api/cron",      "dest": "/api/cron" },
    { "src": "/(.*)",          "dest": "/api/index" }
  ],
  "functions": {
    "api/**/*.js": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/cron?secret=YOUR_CRON_SECRET_HERE",
      "schedule": "0 0 * * *"
    }
  ]
}